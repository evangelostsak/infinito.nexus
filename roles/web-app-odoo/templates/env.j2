#############################################
# Odoo Docker Environment (.env)
#############################################

# ------------------------------------------------
# Database connection (used by Odoo container)
# ------------------------------------------------
HOST={{ ODOO_DATABASE_HOST }}
PORT={{ ODOO_DATABASE_PORT }}
USER={{ ODOO_DATABASE_USER }}
PASSWORD={{ ODOO_DATABASE_PASSWORD | dotenv_quote }}

# ------------------------------------------------
# PostgreSQL initialization (used by postgres container)
# ------------------------------------------------
POSTGRES_DB={{ ODOO_DATABASE_NAME }}
POSTGRES_USER={{ ODOO_DATABASE_USER }}
POSTGRES_PASSWORD={{ ODOO_DATABASE_PASSWORD | dotenv_quote }}
