# Pre-loaded via RUBYOPT. Refuses any telegram/* require and pre-declares
# the Telegram::Bot namespace so Zammad's own references resolve while the
# broken telegram-bot-ruby 2.4.0 gem never loads. Telegram channel is
# consequently inert — that's fine, we never configure it.
module Telegram
  module Bot
    module Types
    end
    class Client; end
    class Api;    end
  end
end

module Kernel
  alias_method :_orig_require_pre_telegram_shim, :require
  def require(path)
    p = path.to_s
    return false if p.start_with?("telegram/") || p.start_with?("telegram-bot")
    _orig_require_pre_telegram_shim(p)
  end
end
