# Database (central svc-db-postgres when shared, else stack-internal)
POSTGRESQL_HOST={{ lookup('database', application_id, 'host') }}
POSTGRESQL_PORT={{ lookup('database', application_id, 'port') }}
POSTGRESQL_DB={{ lookup('database', application_id, 'name') }}
POSTGRESQL_USER={{ lookup('database', application_id, 'username') }}
POSTGRESQL_PASS={{ lookup('database', application_id, 'password') | dotenv_quote }}
# DATABASE_URL is normally computed by /docker-entrypoint.sh, but we need it
# pre-populated so that `container exec ... rails r` (without entrypoint) works
# for post-bootstrap config tasks.
DATABASE_URL=postgres://{{ lookup('database', application_id, 'username') }}:{{ lookup('database', application_id, 'password') | urlencode }}@{{ lookup('database', application_id, 'host') }}:{{ lookup('database', application_id, 'port') }}/{{ lookup('database', application_id, 'name') }}

# Redis (used for Sidekiq + WebSocket)
REDIS_URL=redis://redis:6379

# Memcached (Rails cache) — bundled inside this role's compose stack
MEMCACHE_SERVERS={{ ZAMMAD_MEMCACHED_CONTAINER }}:11211

# Elasticsearch (bundled)
ELASTICSEARCH_HOST={{ ZAMMAD_SEARCH_CONTAINER }}
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEMA=http
ELASTICSEARCH_NAMESPACE=zammad
ELASTICSEARCH_REINDEX=true

# Zammad runtime
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
# Disable Rails eager-loading to sidestep the upstream Zammad 6.5.0
# `NameError: uninitialized constant Telegram::Bot::Types::TransactionPartnerFragment`
# crash at boot (gem-version mismatch in `telegram-bot-ruby`). Lazy autoload
# pays a small per-request init cost on first hit, but never references the
# missing constant.
RAILS_EAGER_LOAD=false
# Pre-load the Telegram boot shim so transaction_partner.rb's deprecate_constant
# call doesn't crash Rails app load. See templates/zz_telegram_constant_shim.rb.j2.
RUBYOPT=-r/opt/zammad/zz_telegram_constant_shim.rb
NGINX_SERVER_NAME={{ ZAMMAD_HOSTNAME }}
NGINX_SERVER_SCHEME={{ ZAMMAD_WEB_PROTOCOL }}
ZAMMAD_RAILSSERVER_HOST={{ ZAMMAD_RAILS_CONTAINER }}
ZAMMAD_RAILSSERVER_PORT={{ ZAMMAD_RAILS_PORT }}
ZAMMAD_WEBSOCKET_HOST={{ ZAMMAD_WEBSOCKET_CONTAINER }}
ZAMMAD_WEBSOCKET_PORT={{ ZAMMAD_WEBSOCKET_PORT }}
TZ={{ HOST_TIMEZONE }}

# Wizard bypass (set on first deploy; ignored once setup is complete)
# WEB_CONCURRENCY=0 disables puma's cluster-mode app preload, which sidesteps
# the upstream Zammad 6.5.0 eager-load crash `uninitialized constant
# Telegram::Bot::Types::TransactionPartnerFragment` (gem-version mismatch).
ZAMMAD_WEB_CONCURRENCY=0
ZAMMAD_SECRET_KEY_BASE={{ ZAMMAD_SECRET_KEY_BASE | dotenv_quote }}

# Trust the reverse proxy (sys-svc-proxy) for real client IPs.
# Upstream env name per /docker-entrypoint.sh.
RAILS_TRUSTED_PROXIES={{ NETWORK_TRUSTED_PROXY_CIDRS | join(',') }}
