PENPOT_FLAGS=enable-log-emails
PENPOT_PUBLIC_URI={{ penpot_public_url }}
PENPOT_SECRET_KEY={{ penpot_secret_key | dotenv_quote }}

PENPOT_DATABASE_URI={{ penpot_database_uri }}
PENPOT_DATABASE_USERNAME={{ penpot_database_username }}
PENPOT_DATABASE_PASSWORD={{ penpot_database_password | dotenv_quote }}

PENPOT_REDIS_URI={{ penpot_redis_uri }}

PENPOT_OBJECTS_STORAGE_BACKEND=s3
PENPOT_OBJECTS_STORAGE_S3_REGION={{ penpot_minio_region }}
PENPOT_OBJECTS_STORAGE_S3_BUCKET={{ penpot_minio_bucket }}
PENPOT_OBJECTS_STORAGE_S3_ENDPOINT={{ penpot_minio_endpoint }}
AWS_ACCESS_KEY_ID={{ penpot_minio_access_key }}
AWS_SECRET_ACCESS_KEY={{ penpot_minio_secret_key | dotenv_quote }}

PENPOT_BACKEND_URI=http://{{ penpot_backend_service }}:{{ penpot_backend_port_internal }}
PENPOT_EXPORTER_URI=http://{{ penpot_exporter_service }}:{{ penpot_exporter_port_internal }}
