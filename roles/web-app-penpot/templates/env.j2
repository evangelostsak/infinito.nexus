PENPOT_FLAGS=enable-log-emails{% if penpot_oidc_enabled | bool %} enable-login-with-oidc{% endif %}{% if penpot_ldap_enabled | bool %} enable-login-with-ldap{% endif %}

{% if penpot_oidc_enabled | bool %}
PENPOT_OIDC_CLIENT_ID={{ OIDC.CLIENT.ID }}
PENPOT_OIDC_CLIENT_SECRET={{ OIDC.CLIENT.SECRET | dotenv_quote }}
PENPOT_OIDC_BASE_URI={{ OIDC.CLIENT.ISSUER_URL }}
PENPOT_OIDC_AUTH_URI={{ OIDC.CLIENT.ISSUER_URL }}/protocol/openid-connect/auth
PENPOT_OIDC_TOKEN_URI={{ OIDC.CLIENT.ISSUER_URL }}/protocol/openid-connect/token
PENPOT_OIDC_USER_URI={{ OIDC.CLIENT.ISSUER_URL }}/protocol/openid-connect/userinfo
PENPOT_OIDC_NAME=Login with SSO
{% endif %}

{% if penpot_ldap_enabled | bool %}
PENPOT_LDAP_HOST={{ penpot_ldap_host }}
PENPOT_LDAP_PORT={{ penpot_ldap_port }}
PENPOT_LDAP_SSL={{ penpot_ldap_ssl | ternary('true', 'false') }}
PENPOT_LDAP_STARTTLS={{ penpot_ldap_starttls | ternary('true', 'false') }}
PENPOT_LDAP_BASE_DN={{ penpot_ldap_base_dn }}
PENPOT_LDAP_BIND_DN={{ penpot_ldap_bind_dn }}
PENPOT_LDAP_BIND_PASSWORD={{ penpot_ldap_bind_password | dotenv_quote }}
PENPOT_LDAP_USER_QUERY={{ penpot_ldap_user_query | dotenv_quote }}
PENPOT_LDAP_ATTRS_USERNAME={{ LDAP.USER.ATTRIBUTES.ID }}
PENPOT_LDAP_ATTRS_EMAIL={{ LDAP.USER.ATTRIBUTES.MAIL }}
PENPOT_LDAP_ATTRS_FULLNAME={{ LDAP.USER.ATTRIBUTES.FULLNAME }}
{% endif %}

PENPOT_PUBLIC_URI={{ penpot_public_url }}
PENPOT_SECRET_KEY={{ penpot_secret_key | dotenv_quote }}

PENPOT_DATABASE_URI={{ penpot_database_uri }}
PENPOT_DATABASE_USERNAME={{ penpot_database_username }}
PENPOT_DATABASE_PASSWORD={{ penpot_database_password | dotenv_quote }}

PENPOT_REDIS_URI={{ penpot_redis_uri }}

PENPOT_OBJECTS_STORAGE_BACKEND=s3
PENPOT_OBJECTS_STORAGE_S3_REGION={{ penpot_minio_region }}
PENPOT_OBJECTS_STORAGE_S3_BUCKET={{ penpot_minio_bucket if penpot_minio_bucket not in ['undefined', '', none] else 'penpot-assets' }}
PENPOT_OBJECTS_STORAGE_S3_ENDPOINT={{ penpot_minio_endpoint }}
AWS_ACCESS_KEY_ID={{ penpot_minio_access_key }}
AWS_SECRET_ACCESS_KEY={{ penpot_minio_secret_key | dotenv_quote }}

PENPOT_BACKEND_URI=http://{{ penpot_backend_service }}:{{ penpot_backend_port_internal }}
PENPOT_EXPORTER_URI=http://{{ penpot_exporter_service }}:{{ penpot_exporter_port_internal }}
